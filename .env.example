# Sanity project configuration.
# Create a project at https://www.sanity.io/manage, then copy these values.
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production

# Optional: a read token for previewing draft/unpublished content (server-side only).
# Leave unset to read only published documents via the public API.
SANITY_API_READ_TOKEN=

# Required for the contact form API (/api/contact). Create an Editor token at
# https://www.sanity.io/manage — never expose this in client-side code.
SANITY_API_WRITE_TOKEN=
