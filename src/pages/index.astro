---
import BaseLayout from "../layouts/BaseLayout.astro";
import SanityImage from "../components/SanityImage.astro";
import RichText from "../components/RichText.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import {
	getSiteSettings,
	getChapters,
	getGalleryBySlug,
} from "../lib/sanity/queries";

const [settings, chapters, powerGallery] = await Promise.all([
	getSiteSettings(),
	getChapters(),
	getGalleryBySlug("what-is-your-power"),
]);

const heroHeading = settings?.heroHeading ?? "A State of Becoming";
const heroImages = settings?.heroImages ?? [];
---

<BaseLayout title={settings?.title ?? "A State of Becoming"} wide={true}>
	<section class="hero">
		<div class="enso" aria-hidden="true"></div>
		<div class="hero-inner">
			<div class="hero-text">
				<h1>{heroHeading}</h1>
				{settings?.heroText && <RichText value={settings.heroText} />}
				<a class="hero-cta" href="/chapters">Explore the chapters</a>
			</div>
			{heroImages.length > 0 && (
				<div class="hero-photos">
					{heroImages.slice(0, 2).map((img) => (
						<figure class="photo-container">
							<SanityImage image={img} width={640} alt={img.alt ?? ""} loading="eager" />
							{img.caption && <figcaption>{img.caption}</figcaption>}
						</figure>
					))}
				</div>
			)}
		</div>
	</section>

	{powerGallery && powerGallery.items.length > 0 && (
		<section class="power-section">
			<div class="power-enso" aria-hidden="true"></div>
			<div class="power-inner">
				<h2>What is your power?</h2>
				<p class="power-prose">
					Where does it sit, your power?<br />
					Where do you find the will each day to face the world?<br />
					Search for your power &mdash; only you know where it is.
				</p>
				<p class="power-hint">Click on any image to explore the full story.</p>
				<GalleryGrid
					items={powerGallery.items}
					columns={powerGallery.columns ?? 3}
					id="gallery-home-power"
				/>
			</div>
		</section>
	)}

	<section class="chapters-preview">
		<h2>The chapters</h2>
		<div class="chapter-grid">
			{chapters.map((chapter) => (
				<a class="chapter-card" href={`/chapters/${chapter.slug}`}>
					{chapter.featuredImage && (
						<div class="chapter-card-image">
							<SanityImage image={chapter.featuredImage} width={500} height={340} alt={chapter.title} />
						</div>
					)}
					<div class="chapter-card-body">
						<span class="chapter-number">Chapter {chapter.order}</span>
						<h3>{chapter.title}</h3>
					</div>
				</a>
			))}
		</div>
		{chapters.length === 0 && (
			<p class="empty">
				Content has not been added yet. Visit the <a href="/studio">Studio</a> to begin.
			</p>
		)}
	</section>
</BaseLayout>

<style>
	@keyframes heroRise {
		0% { opacity: 0; transform: translateX(-40px); filter: blur(6px); }
		100% { opacity: 1; transform: translateX(0); filter: blur(0); }
	}
	@keyframes heroPhotoIn {
		0% { opacity: 0; transform: translateX(50px) scale(0.96); filter: blur(8px); }
		100% { opacity: 1; transform: translateX(0) scale(1); filter: blur(0); }
	}

	.hero {
		position: relative;
		padding: 3rem 0 4rem;
		overflow: hidden;
	}
	.enso {
		position: absolute;
		inset: 0;
		background: url("/enso-circle.png") center/min(500px, 80vw) no-repeat;
		opacity: 0.12;
		pointer-events: none;
		-webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 65%);
		mask-image: radial-gradient(ellipse at center, black 35%, transparent 65%);
	}
	.hero-inner {
		position: relative;
		display: grid;
		grid-template-columns: 3fr 1.15fr;
		gap: 2.5rem;
		align-items: center;
	}
	.hero-text h1 {
		font-size: clamp(2.2rem, 5vw, 3.2rem);
		letter-spacing: 0.02em;
		margin-bottom: 1.25rem;
		animation: heroRise 0.8s cubic-bezier(0.2, 0.7, 0.2, 1) both;
	}
	.hero-text :global(.rich-text) {
		font-size: 1.2rem;
		color: rgb(var(--color-neutral-700));
		animation: heroRise 0.8s cubic-bezier(0.2, 0.7, 0.2, 1) both;
		animation-delay: 0.15s;
	}
	.hero-cta {
		display: inline-block;
		margin-top: 1.5rem;
		padding: 0.8em 1.6em;
		background: rgb(var(--color-primary-600));
		color: #fff;
		border-radius: 8px;
		font-weight: 600;
		text-decoration: none;
		animation: heroRise 0.8s cubic-bezier(0.2, 0.7, 0.2, 1) both;
		animation-delay: 0.4s;
	}
	.hero-cta:hover {
		background: rgb(var(--color-primary-700));
		text-decoration: none;
	}
	.hero-photos {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}
	.photo-container {
		margin: 0;
		animation: heroPhotoIn 0.9s cubic-bezier(0.2, 0.7, 0.2, 1) both;
		animation-delay: 0.3s;
	}
	.photo-container :global(img) {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 16px 32px rgba(var(--color-neutral-900), 0.14);
	}
	.photo-container figcaption {
		font-size: 0.85rem;
		color: rgb(var(--color-neutral-500));
		margin-top: 0.5rem;
		text-align: center;
	}

	.power-section {
		position: relative;
		margin-top: 4rem;
		padding: 3rem 0;
		text-align: center;
		overflow: hidden;
	}
	.power-enso {
		position: absolute;
		inset: 0;
		background: url("/enso-circle.png") center/min(500px, 80vw) no-repeat;
		opacity: 0.12;
		pointer-events: none;
		-webkit-mask-image: radial-gradient(ellipse at center, black 35%, transparent 65%);
		mask-image: radial-gradient(ellipse at center, black 35%, transparent 65%);
	}
	.power-inner {
		position: relative;
		z-index: 1;
	}
	.power-prose {
		font-size: clamp(1.3rem, 3vw, 1.75rem);
		font-weight: 600;
		line-height: 1.7;
		max-width: 48rem;
		margin: 1rem auto 0.5rem;
		color: rgb(var(--color-neutral-800));
	}
	.power-hint {
		color: rgb(var(--color-neutral-500));
		font-size: 0.95rem;
		margin-bottom: 2rem;
	}

	.chapters-preview {
		margin-top: 4rem;
	}
	.chapters-preview h2 {
		text-align: center;
		margin-bottom: 2rem;
	}
	.chapter-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.5rem;
	}
	.chapter-card {
		display: flex;
		flex-direction: column;
		border-radius: 12px;
		overflow: hidden;
		background: rgb(var(--color-neutral));
		border: 1px solid rgb(var(--color-neutral-200));
		color: inherit;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}
	.chapter-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 16px 32px rgba(var(--color-neutral-900), 0.12);
		text-decoration: none;
	}
	.chapter-card-image {
		aspect-ratio: 3 / 2;
		overflow: hidden;
	}
	.chapter-card-image :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.chapter-card-body {
		padding: 1.1rem 1.25rem;
	}
	.chapter-number {
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--color-primary-600));
	}
	.chapter-card-body h3 {
		font-size: 1.2rem;
		margin: 0.35rem 0 0;
	}
	.empty {
		text-align: center;
		color: rgb(var(--color-neutral-500));
	}

	@media (max-width: 720px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}
		.hero-photos {
			flex-direction: row;
		}
	}
</style>
