---
import { SITE_TITLE } from "../consts";
const today = new Date();
---

<footer>
	<p class="footer-title">{SITE_TITLE}</p>
	<p class="footer-meta">
		&copy; {today.getFullYear()} Dinos Aristidou &amp; Neil Farrelly. All rights reserved.
	</p>
	<nav class="footer-links">
		<a href="/chapters">Chapters</a>
		<a href="/about">About</a>
		<a href="/contact">Contact</a>
	</nav>
</footer>

<style>
	footer {
		flex-shrink: 0;
		padding: 3em 1em 4em;
		background: rgb(var(--color-neutral-100));
		border-top: 1px solid rgb(var(--color-neutral-200));
		color: rgb(var(--color-neutral-600));
		text-align: center;
	}
	.footer-title {
		font-weight: 700;
		color: rgb(var(--color-neutral-800));
		margin-bottom: 0.25em;
	}
	.footer-meta {
		font-size: 0.9rem;
		margin-bottom: 1em;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
	}
	.footer-links a {
		color: rgb(var(--color-neutral-600));
		font-size: 0.95rem;
	}
</style>
