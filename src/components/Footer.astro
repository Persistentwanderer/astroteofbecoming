---
import { SITE_TITLE } from "../consts";
const today = new Date();
---

<footer>
	<div class="footer-bar">
		<p class="footer-meta">
			&copy; {today.getFullYear()} {SITE_TITLE}
		</p>
		<p class="footer-credit">Website by Alfie Zanini</p>
	</div>
</footer>

<style>
	footer {
		flex-shrink: 0;
		padding: 2.5em 1.5em 3em;
		background: rgb(var(--color-neutral-100));
		border-top: 1px solid rgb(var(--color-neutral-200));
		color: rgb(var(--color-neutral-600));
	}
	.footer-bar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem 1.5rem;
		max-width: var(--wide-width);
		margin: 0 auto;
	}
	.footer-meta,
	.footer-credit {
		font-size: 0.9rem;
		margin: 0;
	}
	.footer-credit {
		font-size: 0.85rem;
		color: rgb(var(--color-neutral-500));
	}
</style>
