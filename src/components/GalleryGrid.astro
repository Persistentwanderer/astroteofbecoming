---
import { urlFor } from "../lib/sanity/image";
import { portableTextToHtml } from "../lib/sanity/portableTextToHtml";
import type { GalleryItem } from "../lib/sanity/types";

interface Props {
	items: GalleryItem[];
	columns?: number;
	id?: string;
}

const { items, columns = 3, id = "gallery-grid" } = Astro.props;

// Grid thumbs stay small; lightbox loads a larger image in the background.
const prepared = items.map((item) => {
	const thumb = item.image?.asset
		? urlFor(item.image).width(600).auto("format").url()
		: "";
	const full = item.image?.asset
		? urlFor(item.image).width(1400).auto("format").url()
		: thumb;
	// Uploaded video file takes priority; fall back to an external URL.
	const video = item.videoFileUrl ?? item.videoUrl ?? "";
	// A self-hosted/direct file can play inline; YouTube/Vimeo open out.
	const inlineVideo =
		!!item.videoFileUrl ||
		(!!item.videoUrl && /\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(item.videoUrl));
	return {
		thumb,
		full,
		title: item.title ?? "",
		author: item.author ?? "",
		description: portableTextToHtml(item.description),
		fullStory: portableTextToHtml(item.fullStory),
		link: item.externalLink ?? (inlineVideo ? "" : video),
		video: inlineVideo ? video : "",
		audio: item.audioUrl ?? "",
		titleStyle: item.titleStyle ?? "default",
	};
});
---

<div id={id} class="gallery-grid-container" data-gallery-id={id}>
	<div class:list={["gallery-grid", `gallery-grid-cols-${columns}`]}>
		{prepared.map((item, index) => (
			<div
				class="gallery-item"
				data-index={index}
				data-thumb={item.thumb}
				data-full={item.full}
				data-title={item.title}
				data-author={item.author}
				data-description={item.description}
				data-full-story={item.fullStory}
				data-link={item.link}
				data-video={item.video}
				data-audio={item.audio}
				data-title-style={item.titleStyle}
			>
				<img src={item.thumb} alt={item.title} loading="lazy" decoding="async" />
				{item.video && <span class="gallery-item-play" aria-hidden="true"></span>}
			</div>
		))}
	</div>

	<div class="gallery-lightbox" id={`${id}-lightbox`} role="dialog" aria-modal="true" aria-label="Gallery Lightbox">
		<button class="gallery-lightbox-close" aria-label="Close gallery">&times;</button>
		<button class="gallery-lightbox-prev" aria-label="Previous image">&#8249;</button>
		<button class="gallery-lightbox-next" aria-label="Next image">&#8250;</button>
		<div class="gallery-lightbox-content">
			<div class="gallery-lightbox-image-wrapper">
				<img class="gallery-lightbox-image" src="" alt="" loading="eager" />
				<video class="gallery-lightbox-video" controls playsinline preload="metadata" style="display:none;"></video>
			</div>
			<div class="gallery-lightbox-caption">
				<div class="gallery-lightbox-caption-inner">
					<h3 class="gallery-lightbox-title"></h3>
					<p class="gallery-lightbox-author"></p>
					<div class="gallery-lightbox-description"></div>
					<div class="gallery-lightbox-actions">
						<a class="gallery-lightbox-link" href="" target="_blank" rel="noopener noreferrer" style="display:none;"></a>
						<button type="button" class="gallery-lightbox-action gallery-lightbox-story-btn" style="display:none;">Read full text</button>
						<button type="button" class="gallery-lightbox-action gallery-lightbox-audio-btn" style="display:none;" aria-label="Play audio">Listen</button>
					</div>
					<audio class="gallery-lightbox-audio" style="display:none;"></audio>
				</div>
			</div>
		</div>
	</div>
</div>

<style is:global>
	.gallery-grid-container {
		width: 100%;
		margin: 0 auto;
	}
	.gallery-grid {
		position: relative;
		width: 100%;
		min-height: 0;
	}
	.gallery-item {
		position: absolute;
		cursor: pointer;
		overflow: hidden;
		transition: transform 0.2s ease, opacity 0.2s ease;
		width: calc(50% - 5px);
		margin: 0;
		padding: 0;
		box-sizing: border-box;
		line-height: 0;
		border-radius: 8px;
	}
	.gallery-grid-cols-3 .gallery-item {
		width: calc(33.333% - 6.67px);
	}
	.gallery-item:hover {
		transform: translateY(-2px);
		opacity: 0.9;
	}
	.gallery-item img {
		width: 100%;
		height: auto;
		display: block;
		vertical-align: top;
		border-radius: 8px;
	}
	.gallery-item-play {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 56px;
		height: 56px;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.55);
		pointer-events: none;
	}
	.gallery-item-play::after {
		content: "";
		position: absolute;
		top: 50%;
		left: 54%;
		transform: translate(-50%, -50%);
		border-style: solid;
		border-width: 11px 0 11px 18px;
		border-color: transparent transparent transparent #fff;
	}
	@media (max-width: 768px) {
		.gallery-item,
		.gallery-grid-cols-3 .gallery-item {
			width: 100% !important;
			left: 0 !important;
		}
	}

	.gallery-lightbox {
		display: none;
		position: fixed;
		inset: 0;
		background-color: rgba(245, 246, 250, 0.97);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		z-index: 10000;
		overflow: hidden;
	}
	.gallery-lightbox.active {
		display: block;
	}
	/*
	  Two-row grid: a flexible media row that always contains the image/video,
	  and an auto-sized caption row pinned to the bottom. Using a grid track
	  (rather than flex sizing) makes the media area a hard-bounded box, so
	  media can never clip out of it and the caption can never float away from
	  the bottom regardless of aspect ratio or caption length.
	*/
	.gallery-lightbox-content {
		position: absolute;
		/* Pin to the dynamic viewport height so the grid always matches the
		   visible area (avoids the 100vh vs dvh mismatch on mobile that let
		   centred media drift under the top controls). */
		inset: 0 0 auto 0;
		height: 100dvh;
		display: grid;
		grid-template-rows: minmax(0, 1fr) auto;
		justify-items: center;
		overflow: hidden;
		/* Reserve top space so tall media never slides under the fixed
		   close button (top: 20px, 50px tall) or the safe-area inset. */
		padding: max(80px, calc(env(safe-area-inset-top, 0px) + 64px)) 20px 0;
		box-sizing: border-box;
	}
	.gallery-lightbox-image-wrapper {
		grid-row: 1;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 0;
		min-width: 0;
		overflow: hidden;
		/* Bottom padding doubles as the gap above the caption. */
		padding: 0 10px 12px;
		box-sizing: border-box;
	}
	.gallery-lightbox-image {
		max-width: 100%;
		max-height: 100%;
		width: auto;
		height: auto;
		object-fit: contain;
		pointer-events: none;
		display: block;
		border-radius: 6px;
		box-shadow: 0 10px 40px rgba(15, 23, 42, 0.12), 0 2px 6px rgba(15, 23, 42, 0.06);
		transition: filter 0.2s ease;
	}
	.gallery-lightbox-image.is-upgrading {
		filter: blur(0.5px);
	}
	/* Video fills the media track and is letterboxed via object-fit, so small
	   or low-res clips scale up to fit instead of floating at intrinsic size. */
	.gallery-lightbox-video {
		width: 100%;
		height: 100%;
		display: block;
		border-radius: 6px;
		background: transparent;
		object-fit: contain;
	}
	.gallery-lightbox-caption {
		grid-row: 2;
		width: 100%;
		max-width: 95vw;
		margin-inline: auto;
		max-height: 50dvh;
		background-color: #fff;
		box-sizing: border-box;
		border-radius: 12px 12px 0 0;
		box-shadow: 0 -4px 24px rgba(15, 23, 42, 0.08);
		display: flex;
		flex-direction: column;
		overflow-x: hidden;
		overflow-y: auto;
		overscroll-behavior: contain;
	}
	.gallery-lightbox-caption.hidden {
		display: none !important;
	}
	.gallery-lightbox-caption.minimal {
		padding: 15px 30px;
	}
	.gallery-lightbox-caption.normal {
		padding: 20px 35px;
	}
	.gallery-lightbox-caption.full {
		padding: 25px 20px;
		padding-bottom: calc(25px + env(safe-area-inset-bottom, 0px));
	}
	.gallery-lightbox-caption-inner {
		max-width: 100%;
		width: 100%;
		display: flex;
		flex-direction: column;
		padding-inline: 15px;
		box-sizing: border-box;
	}
	.gallery-lightbox-title {
		margin: 0 0 8px 0;
		font-size: 1.5rem;
		font-weight: 600;
		color: #1a1a1a;
		text-decoration: underline;
		text-decoration-thickness: 2px;
		text-underline-offset: 4px;
		line-height: 1.25;
	}
	.gallery-lightbox-title.wacky {
		font-family: "Chalkduster", "Marker Felt", "Bradley Hand ITC", cursive, fantasy;
		font-weight: 400;
		font-style: italic;
		letter-spacing: 0.04em;
		line-height: 1.5;
		margin-bottom: 1.25rem;
		padding-bottom: 0.35em;
		transform: rotate(-1.25deg);
		color: #3d1f6b;
		text-decoration-style: wavy;
		text-underline-offset: 0.25em;
	}
	.gallery-lightbox-author {
		margin: 0 0 10px 0;
		font-size: 1rem;
		color: #4a4a4a;
		font-style: italic;
	}
	.gallery-lightbox-description {
		margin: 0 0 15px 0;
		font-size: 1rem;
		line-height: 1.6;
		color: #333;
	}
	.gallery-lightbox-description :last-child {
		margin-bottom: 0;
	}
	.gallery-lightbox-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 10px;
		margin-top: 12px;
	}
	.gallery-lightbox-actions .gallery-lightbox-link,
	.gallery-lightbox-actions .gallery-lightbox-action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		padding: 12px 24px;
		background-color: rgb(var(--color-primary-600));
		color: #fff !important;
		border: none;
		border-radius: 6px;
		font-weight: 500;
		font-size: 1rem;
		font-family: inherit;
		text-decoration: none;
		cursor: pointer;
		transition: background-color 0.2s ease, transform 0.2s ease;
	}
	.gallery-lightbox-actions .gallery-lightbox-link:hover,
	.gallery-lightbox-actions .gallery-lightbox-action:hover {
		background-color: rgb(var(--color-primary-700));
		transform: translateY(-1px);
	}
	.gallery-lightbox-close,
	.gallery-lightbox-prev,
	.gallery-lightbox-next {
		position: fixed;
		background: rgba(26, 26, 26, 0.12);
		border: none;
		color: #1a1a1a;
		font-size: 2rem;
		width: 50px;
		height: 50px;
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background-color 0.2s ease, transform 0.2s ease;
		z-index: 10001;
		backdrop-filter: blur(5px);
	}
	.gallery-lightbox-close:hover,
	.gallery-lightbox-prev:hover,
	.gallery-lightbox-next:hover {
		background: rgba(26, 26, 26, 0.22);
	}
	.gallery-lightbox-close {
		top: 20px;
		left: 20px;
		font-size: 2.5rem;
		line-height: 1;
	}
	.gallery-lightbox-prev {
		left: 20px;
		top: 50%;
		transform: translateY(-50%);
	}
	.gallery-lightbox-next {
		right: 20px;
		top: 50%;
		transform: translateY(-50%);
	}
	.gallery-lightbox-prev:hover,
	.gallery-lightbox-next:hover {
		transform: translateY(-50%) scale(1.1);
	}
	body.gallery-lightbox-open {
		overflow: hidden;
	}
	/* On desktop the prev/next arrows sit at the vertical centre; keep the
	   media clear of them so wide images don't slide underneath. */
	@media (min-width: 769px) {
		.gallery-lightbox-image-wrapper {
			padding-inline: 80px;
		}
	}
	@media (max-width: 768px) {
		.gallery-lightbox-prev,
		.gallery-lightbox-next {
			display: none;
		}
		.gallery-lightbox-actions {
			flex-direction: column;
			align-items: stretch;
		}
	}
</style>

<script>
	import { initGalleries } from "../scripts/gallery";
	initGalleries();
	document.addEventListener("astro:page-load", () => initGalleries());
</script>
