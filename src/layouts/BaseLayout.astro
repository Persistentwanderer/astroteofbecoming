---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getChapters } from "../lib/sanity/queries";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	wide?: boolean;
	homepage?: boolean;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	wide = false,
	homepage = false,
} = Astro.props;

// Chapters drive the navigation, in book order.
let chapters: { title: string; slug: string }[] = [];
try {
	chapters = await getChapters();
} catch {
	chapters = [];
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class:list={[homepage && "is-homepage"]}>
		<Header chapters={chapters} />
		{homepage && <slot name="homepage-bg" />}
		<main class:list={[wide && "wide", homepage && "homepage"]}>
			<slot />
		</main>
		<Footer />
		{homepage && (
			<script is:inline>
				(function () {
					var RATE = 0.15;
					var SEL = ".homepage-bg-parallax";
					var layer = null;
					var ticking = false;
					var idleTimer = 0;

					function update() {
						ticking = false;
						if (!layer) return;
						layer.style.transform =
							"translate3d(0, " + -window.scrollY * RATE + "px, 0)";
					}

					function onScroll() {
						if (!layer) return;
						// Promote to its own layer only while actively scrolling,
						// then release it so a heavy open gallery doesn't compound GPU cost.
						if (layer.style.willChange !== "transform") {
							layer.style.willChange = "transform";
						}
						if (!ticking) {
							ticking = true;
							requestAnimationFrame(update);
						}
						clearTimeout(idleTimer);
						idleTimer = setTimeout(function () {
							layer.style.willChange = "auto";
						}, 200);
					}

					function init() {
						layer = document.querySelector(SEL);
						if (!layer) return;
						update();
						window.removeEventListener("scroll", onScroll);
						window.addEventListener("scroll", onScroll, { passive: true });
					}

					init();
					document.addEventListener("astro:page-load", init);
				})();
			</script>
		)}
	</body>
</html>
